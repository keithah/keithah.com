---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts    = await getCollection('posts',    p => !p.data.draft);
const projects = await getCollection('projects');

const recentPosts = posts.sort((a,b) => b.data.date.valueOf() - a.data.date.valueOf()).slice(0,5);

// Featured work: products first, then by status priority. Show 4 max.
const rank = { active: 0, beta: 1, stable: 2, internal: 3, archived: 4 };
const featured = [...projects].sort((a, b) => {
  if (a.data.isProduct !== b.data.isProduct) return a.data.isProduct ? -1 : 1;
  return (rank[a.data.status] ?? 9) - (rank[b.data.status] ?? 9);
}).slice(0, 4);
---
<Base>
  <div class="sh" style="margin-bottom:4px">$ whoami</div>
  <h1 class="hero-name">Keith Herrington</h1>
  <p class="hero-bio">I build tools for streaming infrastructure, open-source media, and stream analysis.</p>
  <p class="hero-role">Technical PM &middot; open-source builder &middot; Executive Director, Kodi Foundation</p>

  <div class="tags" style="margin-bottom:32px">
    <a class="tag" href="https://plex.tv" target="_blank" rel="noopener">streaming</a>
    <a class="tag hl" href="https://homebridge.io" target="_blank" rel="noopener">home automation</a>
    <a class="tag" href="https://asterisk.org" target="_blank" rel="noopener">telecom</a>
    <a class="tag hl" href="https://vivalahiphop.com" target="_blank" rel="noopener">hip hop</a>
    <a class="tag" href="https://thedailychurnpodcast.com" target="_blank" rel="noopener">travel</a>
    <a class="tag hl" href="https://matrix.to/#/@keithah:beeper.com" target="_blank" rel="noopener">matrix</a>
  </div>

  {recentPosts.length > 0 && (
    <>
      <div class="sh">recent posts</div>
      <div class="post-list" style="margin-bottom:32px">
        {recentPosts.map(p => (
          <div class="post-row">
            <span class="post-date">{p.data.date.toISOString().slice(0,10)}</span>
            <a href={`/posts/${p.slug}`} class="post-title">{p.data.title}</a>
            <span class="pill pill-post">post</span>
          </div>
        ))}
      </div>
    </>
  )}

  <hr />

  <div class="sh">featured work</div>
  <div class="card-grid" style="margin-bottom:8px">
    {featured.map(p => (
      <div class={`card ${p.data.isProduct ? 'is-product' : ''}`}>
        <div class="card-top">
          <span class="card-name">{p.data.name}</span>
          <div class="card-meta">
            {p.data.isProduct && <span class="card-product-pill">app</span>}
            <span class="card-lang">{p.data.lang}</span>
          </div>
        </div>
        <p class="card-desc">{p.data.description}</p>
        <div class="card-links">
          <a href={p.data.repo} class="gh" target="_blank" rel="noopener">github</a>
          {p.data.isProduct && <a href={`/products/${p.id.replace('.json','')}`} class="prod">product page &rarr;</a>}
        </div>
      </div>
    ))}
  </div>
  <p style="margin-bottom:28px"><a href="/work" class="see-all">&rarr; see all work</a></p>

  <hr />

  <div class="status-row">
    {projects.map(p => (
      <div class="status">
        <span class={`dot ${p.data.status === 'active' || p.data.status === 'stable' ? '' : p.data.status === 'beta' ? 'amber' : 'dim'}`}></span>
        {p.data.name.toLowerCase()} &middot; {p.data.status}
      </div>
    ))}
  </div>
</Base>
