---
import Base from '../layouts/Base.astro';
---
<Base title="About" activeNav="about">
  <div class="sh" style="margin-bottom:4px">$ cat about.md</div>
  <h1 style="font-size:20px;font-weight:500;margin-bottom:20px">Keith Herrington</h1>

  <div class="prose" style="margin-bottom:32px">
    <p>Technical Product Manager at TuneIn (acquired by Stingray), working across Broadcaster Services, DSA, and Product. Previously shipped streaming infrastructure, ad marker detection tooling, and EPG integrations for broadcast radio.</p>
    <p>Executive Director of the Kodi Foundation, a 501(c)(3) nonprofit. Handling governance, trademark, DevCon logistics, and donation infrastructure for one of the largest open source media projects.</p>
    <p>Indie developer building tools in the gaps — network diagnostics, meeting transcription, stream analysis. Aspirational slopcoder.</p>
  </div>

  <hr />

  <div class="sh" style="margin-bottom:12px">find me</div>
  <div class="about-table">
    <div class="about-row">
      <span class="about-platform">github</span>
      <a href="https://github.com/keithah" class="about-handle" target="_blank" rel="noopener">github.com/keithah</a>
      <span class="about-desc">code &amp; projects</span>
    </div>
    <div class="about-row">
      <span class="about-platform">linkedin</span>
      <a href="https://linkedin.com/in/keithah" class="about-handle" target="_blank" rel="noopener">linkedin.com/in/keithah</a>
      <span class="about-desc">work history</span>
    </div>
    <div class="about-row">
      <span class="about-platform">X</span>
      <a href="https://x.com/keithah" class="about-handle" target="_blank" rel="noopener">x.com/keithah</a>
      <span class="about-desc">hot takes</span>
    </div>
    <div class="about-row">
      <span class="about-platform">matrix</span>
      <a href="https://matrix.to/#/@keithah:beeper.com" class="about-handle" target="_blank" rel="noopener">@keithah:beeper.com</a>
      <span class="about-desc">preferred DM</span>
    </div>
    <div class="about-row">
      <span class="about-platform">kodi</span>
      <a href="https://kodi.tv" class="about-handle" target="_blank" rel="noopener">kodi.tv</a>
      <span class="about-desc">exec director</span>
    </div>
    <div class="about-row">
      <span class="about-platform">substack</span>
      <a href="https://keithah.substack.com" class="about-handle" target="_blank" rel="noopener">keithah.substack.com</a>
      <span class="about-desc">longer reads</span>
    </div>
  </div>
</Base>
