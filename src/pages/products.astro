---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
const products = await getCollection('products');
---
<Base title="Products" activeNav="products">
  <div class="sh" style="margin-bottom:4px">$ ls products/</div>
  <h1 style="font-size:20px;font-weight:500;margin-bottom:24px">Products</h1>
  <div class="card-grid">
    {products.map(p => (
      <div class="card is-product">
        <div class="card-top">
          <span class="card-name">{p.data.name}</span>
          <div class="card-meta">
            <span class="card-product-pill">{p.data.version}</span>
            <span class="card-lang">{p.data.lang}</span>
          </div>
        </div>
        <p class="card-desc">{p.data.tagline}</p>
        <div class="card-links">
          <a href={p.data.repo} class="gh" target="_blank" rel="noopener">github</a>
          <a href={`/${p.slug}`} class="prod">keithah.com/{p.slug} &rarr;</a>
        </div>
      </div>
    ))}
  </div>
</Base>
