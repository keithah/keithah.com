---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
const projects = await getCollection('projects');
---
<Base title="Projects" activeNav="projects">
  <div class="sh" style="margin-bottom:4px">$ ls projects/</div>
  <h1 style="font-size:20px;font-weight:500;margin-bottom:24px">Projects</h1>
  <div class="card-grid">
    {projects.map(p => (
      <div class={`card ${p.data.isProduct ? 'is-product' : ''}`}>
        <div class="card-top">
          <span class="card-name">{p.data.name}</span>
          <div class="card-meta">
            {p.data.isProduct && <span class="card-product-pill">product</span>}
            <span class="card-lang">{p.data.lang}</span>
          </div>
        </div>
        <p class="card-desc">{p.data.description}</p>
        <div class="card-links">
          <a href={p.data.repo} class="gh" target="_blank" rel="noopener">github</a>
          {p.data.isProduct && <a href={`/${p.id.replace('.json','')}`} class="prod">product page &rarr;</a>}
        </div>
      </div>
    ))}
  </div>
  <p style="font-size:10px;color:var(--dimmer);margin-top:12px">green border = also has a product page</p>
</Base>
