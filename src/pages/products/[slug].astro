---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const products = await getCollection('products');
  return products.map(p => ({ params: { slug: p.slug }, props: { product: p } }));
}

const { product } = Astro.props;
const { Content } = await product.render();
const d = product.data;

// Pull related posts
const posts = await getCollection('posts', p => !p.data.draft && p.data.products.includes(product.slug));
posts.sort((a,b) => b.data.date.valueOf() - a.data.date.valueOf());
---
<Base title={d.name} description={d.tagline}>
  <nav style="font-size:10px;color:var(--dimmer);margin-bottom:20px">
    <a href="/" style="color:var(--dimmer)">keithah.com</a>
    <span style="margin:0 6px">/</span>
    <span style="color:var(--green)">{product.slug}</span>
    <span style="float:right;display:flex;gap:16px">
      <a href="#docs">docs</a>
      <a href="#changelog">changelog</a>
      <a href="#support">support</a>
      <a href={d.repo} target="_blank" rel="noopener">github</a>
    </span>
  </nav>

  <div class="product-hero">
    <div class="product-hero-head">
      <h1 class="product-name">{d.name}</h1>
      <span class="product-version">{d.version}</span>
    </div>
    <p class="product-tagline">{d.tagline}</p>
    <div class="product-cta-row">
      <a href={d.repo} class="btn" target="_blank" rel="noopener">View on GitHub &rarr;</a>
      <span class="product-meta-row">
        {d.platforms.join(' / ')}
        <span class="product-meta-sep">&middot;</span>{d.lang}
        <span class="product-meta-sep">&middot;</span>MIT
      </span>
    </div>
  </div>

  <hr />

  <div id="docs" class="prose" style="margin-bottom:28px">
    <Content />
  </div>

  {posts.length > 0 && (
    <>
      <hr />
      <div id="changelog">
        <div class="sh" style="margin-bottom:12px">changelog / related posts</div>
        <div class="changelog">
          {posts.map(p => (
            <div class="changelog-row">
              <span class="cl-date">{p.data.date.toISOString().slice(0,10)}</span>
              <a href={`/posts/${p.slug}`} class="cl-msg" style="color:var(--muted)">{p.data.title}</a>
            </div>
          ))}
        </div>
      </div>
    </>
  )}

  <hr />

  <div id="support">
    <div class="sh" style="margin-bottom:12px">support</div>
    <div class="support-box">
      <h3>open an issue</h3>
      <p>Found a bug or have a request? Open an issue on GitHub. Include your OS version and what you were doing when it broke.</p>
      <a href={`${d.repo}/issues/new`} class="btn" target="_blank" rel="noopener">open an issue on GitHub &rarr;</a>
    </div>
  </div>
</Base>
