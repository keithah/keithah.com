---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const products = await getCollection('products');
  return products.map(p => ({ params: { slug: p.slug }, props: { product: p } }));
}

const { product } = Astro.props;
const { Content } = await product.render();
const d = product.data;
const isPingScope = product.slug === 'pingscope';
const isStarwatch = product.slug === 'starwatch';

// Pull related posts
const posts = await getCollection('posts', p => !p.data.draft && p.data.products.includes(product.slug));
posts.sort((a,b) => b.data.date.valueOf() - a.data.date.valueOf());
---
<Base title={d.name} description={d.tagline}>
  {isStarwatch ? (
    <div class="ps-page">
      <nav class="ps-subnav" aria-label="Starwatch sections">
        <a href="/" class="ps-breadcrumb">keithah.com</a>
        <span>/</span>
        <span>starwatch</span>
        <span class="ps-subnav-links">
          <a href="#features">features</a>
          <a href="#install">install</a>
          <a href="#support">support</a>
          <a href={d.repo} target="_blank" rel="noopener">github</a>
        </span>
      </nav>

      <section class="ps-hero sw-hero" aria-labelledby="starwatch-title">
        <div class="ps-hero-copy">
          <p class="ps-eyebrow">Local Starlink control on your router</p>
          <h1 id="starwatch-title" class="sw-title">Starwatch <span class="sw-ver">{d.version}</span></h1>
          <p class="ps-lede">Turn the router behind your Starlink dish into a full-time monitor and control panel — dish telemetry, 30-day history, a merged outage timeline, alerts, and guarded controls, all on the router with no Starlink account and no cloud.</p>
          <div class="sw-install-row">
            <code class="sw-cmd">wget -qO- https://keithah.github.io/openwrt-starwatch/install.sh | sh</code>
            <button class="ps-btn sw-copy" type="button">copy</button>
          </div>
          <div class="ps-actions">
            <a class="ps-btn ps-primary" href={d.repo} target="_blank" rel="noopener">View on GitHub</a>
            <a class="ps-btn ps-ghost" id="sw-release-link" href={`${d.repo}/releases`} target="_blank" rel="noopener">Release notes</a>
          </div>
          <p class="ps-release-note">Signed opkg feed &middot; aarch64_cortex-a53 (GL.iNet &amp; OpenWrt) &middot; AGPL-3.0.</p>
        </div>
        <div class="ps-shot-wrap sw-shot-wrap">
          <img class="sw-shot" src="/products/starwatch/dashboard-overview.png" alt="Starwatch dashboard with icon-rail navigation, live telemetry graph, and status header." />
        </div>
      </section>

      <section id="features" class="ps-section" aria-labelledby="sw-features-title">
        <div class="ps-section-head">
          <h2 id="sw-features-title">Everything the dish knows, kept and made useful.</h2>
          <p>Starwatch reads the dish's local gRPC API once a second, keeps history the dish itself can't, and surfaces it in a dashboard embedded right in LuCI and the GL.iNet panel.</p>
        </div>
        <div class="ps-feature-grid">
          <article class="ps-card">
            <span>01</span>
            <h3>Telemetry &amp; controls</h3>
            <p>Latency, throughput, power draw, obstruction map, alignment, and GPS &mdash; plus audited reboot, stow, snow-melt, sleep schedule, and speed test.</p>
          </article>
          <article class="ps-card">
            <span>02</span>
            <h3>History &amp; outage truth</h3>
            <p>30 days of on-router history, and a merged timeline that tells a dish outage apart from an unreachable dish apart from an upstream path problem.</p>
          </article>
          <article class="ps-card">
            <span>03</span>
            <h3>VPN-proof access</h3>
            <p>A self-healing 192.168.100.1/32 route keeps the dish reachable even when a VPN owns the default route &mdash; without touching your general routing.</p>
          </article>
          <article class="ps-card">
            <span>04</span>
            <h3>Guarded router control</h3>
            <p>On double-NAT setups, read and safely change the Starlink router's Wi-Fi and clients &mdash; readback-confirmed, with write-only passphrases.</p>
          </article>
        </div>
        <div class="ps-overlay-showcase">
          <div>
            <p class="ps-kicker">Panel and phone</p>
            <h3>The same dashboard, in the panel or in your pocket.</h3>
            <p>The seven-section icon rail collapses to a mobile drawer, so the full Overview, telemetry, and controls travel from the GL.iNet Applications panel to your phone &mdash; token-authenticated and offline-first.</p>
          </div>
          <img class="sw-shot-mobile" src="/products/starwatch/dashboard-mobile.png" alt="Starwatch dashboard on a phone showing the mobile section drawer." />
        </div>
      </section>

      <section id="install" class="ps-section" aria-labelledby="sw-install-title">
        <div class="ps-download-panel">
          <div>
            <h2 id="sw-install-title">Install from the signed feed.</h2>
            <p>SSH into your router as root and run the one-liner. It checks your architecture, picks the GL.iNet or LuCI package automatically, pins the feed's signing key, and never forces a downgrade. Then open <strong>Applications &rarr; Starwatch</strong>, <strong>Services &rarr; Starwatch</strong>, or port 9633.</p>
            <div class="sw-install-row">
              <code class="sw-cmd">wget -qO- https://keithah.github.io/openwrt-starwatch/install.sh | sh</code>
              <button class="ps-btn sw-copy" type="button">copy</button>
            </div>
          </div>
          <dl class="ps-release-box">
            <dt>Version</dt>
            <dd id="sw-release-version">{d.version}</dd>
            <dt>Architecture</dt>
            <dd>aarch64_cortex-a53</dd>
            <dt>Feed</dt>
            <dd>usign-signed</dd>
            <dt>Packages</dt>
            <dd><a id="sw-release-assets" href={`${d.repo}/releases`}>daemon + panel app</a></dd>
          </dl>
        </div>
      </section>

      <section id="support" class="ps-section" aria-labelledby="sw-support-title">
        <div class="ps-support-grid">
          <div>
            <h2 id="sw-support-title">Open source, local, and yours.</h2>
            <p>Starwatch is AGPL-3.0. Report bugs or request features as a GitHub issue; security reports go through the private policy in <a href={`${d.repo}/blob/main/SECURITY.md`} target="_blank" rel="noopener">SECURITY.md</a>.</p>
          </div>
          <div class="sw-support-actions">
            <a class="ps-btn ps-primary" href={`${d.repo}/issues/new`} target="_blank" rel="noopener">Open an issue</a>
            <a class="ps-btn" href={d.repo} target="_blank" rel="noopener">Browse the code</a>
          </div>
        </div>
      </section>
    </div>

    <script is:inline>
      document.querySelectorAll('.sw-copy').forEach((btn) => {
        btn.addEventListener('click', () => {
          navigator.clipboard?.writeText('wget -qO- https://keithah.github.io/openwrt-starwatch/install.sh | sh').then(() => {
            const old = btn.textContent; btn.textContent = 'copied'; setTimeout(() => { btn.textContent = old; }, 1400);
          });
        });
      });
      fetch('https://api.github.com/repos/keithah/openwrt-starwatch/releases/latest', { headers: { Accept: 'application/vnd.github+json' } })
        .then((r) => r.ok ? r.json() : Promise.reject())
        .then((rel) => {
          document.getElementById('sw-release-version').textContent = rel.tag_name;
          document.getElementById('sw-release-link').href = rel.html_url;
          const ipks = rel.assets.filter((a) => a.name.endsWith('.ipk')).length;
          const assets = document.getElementById('sw-release-assets');
          if (ipks) assets.textContent = ipks + ' packages';
          assets.href = rel.html_url;
        })
        .catch(() => {});
    </script>
  ) : isPingScope ? (
    <div class="ps-page">
      <nav class="ps-subnav" aria-label="PingScope sections">
        <a href="/" class="ps-breadcrumb">keithah.com</a>
        <span>/</span>
        <span>pingscope</span>
        <span class="ps-subnav-links">
          <a href="#features">features</a>
          <a href="#download">download</a>
          <a href="#support">support</a>
          <a href={d.repo} target="_blank" rel="noopener">github</a>
        </span>
      </nav>

      <section class="ps-hero" aria-labelledby="pingscope-title">
        <div class="ps-hero-copy">
          <p class="ps-eyebrow">Native macOS network visibility</p>
          <div class="ps-title-row">
            <img src="/products/pingscope/app-icon.png" alt="" width="54" height="54" />
            <h1 id="pingscope-title">PingScope</h1>
          </div>
          <p class="ps-lede">A menu-bar latency monitor that tells you whether the problem is local, upstream, or the destination before you start guessing.</p>
          <div class="ps-tease" aria-label="iOS version status">
            <span>Coming soon</span>
            <strong>iOS companion version</strong>
          </div>
          <div class="ps-actions">
            <a class="ps-btn ps-primary" href="https://apps.apple.com/us/app/pingscope-keep-connected/id6759278369?mt=12">Mac App Store</a>
            <a class="ps-btn" id="ps-download" href="https://github.com/keithah/pingscope/releases/download/v0.3.0/PingScope-v0.3.0.dmg">Download 0.3.0</a>
            <a class="ps-btn ps-ghost" href="#support">Support</a>
          </div>
          <p class="ps-release-note" id="ps-release-note">Latest Developer ID release: v0.3.0. This link updates from GitHub when a newer DMG is published.</p>
        </div>
        <div class="ps-shot-wrap">
          <img class="ps-shot" src="/products/pingscope/popover-current.png" alt="PingScope popover showing all hosts, current latency, graph, and recent samples." />
          <div class="ps-float ps-float-top" aria-hidden="true">
            <strong>4ms</strong>
            <span>Healthy</span>
          </div>
          <div class="ps-float ps-float-bottom" aria-hidden="true">
            <strong>3 enabled hosts</strong>
            <span>Cloudflare, Google, and the default gateway shown together.</span>
          </div>
        </div>
      </section>

      <section id="features" class="ps-section" aria-labelledby="ps-features-title">
        <div class="ps-section-head">
          <h2 id="ps-features-title">Built for the moment the network feels wrong.</h2>
          <p>PingScope stays quiet in the menu bar until you need detail. Open the popover for live history, switch hosts, or pin the overlay during calls and debugging sessions.</p>
        </div>
        <div class="ps-feature-grid">
          <article class="ps-card">
            <span>01</span>
            <h3>Always visible</h3>
            <p>A compact status dot and latency readout live in the menu bar, with a floating overlay when a connection needs closer watching.</p>
          </article>
          <article class="ps-card">
            <span>02</span>
            <h3>Failure context</h3>
            <p>Monitor gateway and remote hosts together to tell the difference between Wi-Fi, router, ISP, and destination trouble.</p>
          </article>
          <article class="ps-card">
            <span>03</span>
            <h3>Local first</h3>
            <p>Settings, retained history, exports, and widget snapshots stay on your Mac. Developer ID builds support Sparkle updates.</p>
          </article>
          <article class="ps-card ps-card-ios">
            <span>04</span>
            <h3>iOS is next</h3>
            <p>A companion iPhone view is in progress for checking the same signal away from the menu bar. Mac stays first; mobile is coming.</p>
          </article>
        </div>
        <div class="ps-overlay-showcase">
          <div>
            <p class="ps-kicker">Overlay mode</p>
            <h3>Pin the signal when the connection matters.</h3>
            <p>Keep PingScope floating above calls, uploads, games, and terminal sessions. The overlay stays compact while preserving the latency, health, and loss signals that matter in the moment.</p>
          </div>
          <img src="/products/pingscope/overlay.png" alt="PingScope floating overlay with a latency graph, current status, and packet-loss summary." />
        </div>
      </section>

      <section id="download" class="ps-section" aria-labelledby="ps-download-title">
        <div class="ps-download-panel">
          <div>
            <h2 id="ps-download-title">Download the current macOS build.</h2>
            <p>The App Store build is the simplest install path. The Developer ID DMG is loaded from the latest public GitHub release and has a current static fallback.</p>
            <div class="ps-actions">
              <a class="ps-btn ps-primary" href="https://apps.apple.com/us/app/pingscope-keep-connected/id6759278369?mt=12">Open App Store</a>
              <a class="ps-btn" id="ps-download-secondary" href="https://github.com/keithah/pingscope/releases/download/v0.3.0/PingScope-v0.3.0.dmg">Download 0.3.0 DMG</a>
            </div>
          </div>
          <dl class="ps-release-box" aria-live="polite">
            <dt>Version</dt>
            <dd id="ps-release-version">v0.3.0</dd>
            <dt>Published</dt>
            <dd id="ps-release-date">July 3, 2026</dd>
            <dt>Package</dt>
            <dd id="ps-release-asset">PingScope-v0.3.0.dmg</dd>
            <dt>Notes</dt>
            <dd><a id="ps-release-link" href="https://github.com/keithah/pingscope/releases/tag/v0.3.0">release notes</a></dd>
          </dl>
        </div>
      </section>

      <section id="support" class="ps-section" aria-labelledby="ps-support-title">
        <div class="ps-support-grid">
          <div>
            <h2 id="ps-support-title">Support that starts with useful details.</h2>
            <p>Send a bug report or request to <a href="mailto:keith+pingscope@hadm.net">keith+pingscope@hadm.net</a>. The form opens your email app with the fields filled in.</p>
          </div>
          <form class="ps-form" id="ps-support-form">
            <input type="text" name="name" placeholder="your name" autocomplete="name" />
            <input type="email" name="email" placeholder="email for follow-up" autocomplete="email" />
            <input type="text" name="version" placeholder="PingScope version, if known" />
            <select name="topic">
              <option>Bug report</option>
              <option>Feature request</option>
              <option>Install or update help</option>
              <option>Other</option>
            </select>
            <textarea name="message" placeholder="what happened? Include macOS version, network type, and what you were doing."></textarea>
            <button class="ps-btn ps-primary" type="submit">Email support</button>
          </form>
        </div>
      </section>
    </div>

    <script is:inline>
      const releaseAPI = 'https://api.github.com/repos/keithah/pingscope/releases/latest';
      const downloadButtons = [
        document.getElementById('ps-download'),
        document.getElementById('ps-download-secondary')
      ];
      const versionText = (tagName) => tagName.replace(/^v/i, '');
      const releaseDate = (value) => new Intl.DateTimeFormat('en-US', {
        month: 'long',
        day: 'numeric',
        year: 'numeric'
      }).format(new Date(value));

      fetch(releaseAPI, { headers: { Accept: 'application/vnd.github+json' } })
        .then((response) => {
          if (!response.ok) throw new Error('release lookup failed');
          return response.json();
        })
        .then((release) => {
          const dmg = release.assets.find((asset) => asset.name.endsWith('.dmg'));
          if (!dmg) return;

          const version = versionText(release.tag_name);
          downloadButtons.forEach((button) => {
            button.href = dmg.browser_download_url;
          });
          downloadButtons[0].textContent = `Download ${version}`;
          downloadButtons[1].textContent = `Download ${version} DMG`;
          document.getElementById('ps-release-note').textContent = `Latest Developer ID release: ${release.tag_name}. Download information loaded from GitHub.`;
          document.getElementById('ps-release-version').textContent = release.tag_name;
          document.getElementById('ps-release-date').textContent = releaseDate(release.published_at);
          document.getElementById('ps-release-asset').textContent = dmg.name;
          document.getElementById('ps-release-link').href = release.html_url;
        })
        .catch(() => {
          document.getElementById('ps-release-note').textContent = 'Latest Developer ID release: v0.3.0. GitHub release lookup is temporarily unavailable.';
        });

      document.getElementById('ps-support-form').addEventListener('submit', (event) => {
        event.preventDefault();
        const data = new FormData(event.currentTarget);
        const topic = data.get('topic') || 'Support';
        const body = [
          `Name: ${data.get('name') || ''}`,
          `Email: ${data.get('email') || ''}`,
          `Version: ${data.get('version') || ''}`,
          '',
          data.get('message') || ''
        ].join('\n');
        window.location.href = `mailto:keith+pingscope@hadm.net?subject=${encodeURIComponent(`PingScope support: ${topic}`)}&body=${encodeURIComponent(body)}`;
      });
    </script>
  ) : (
    <>
  <nav style="font-size:10px;color:var(--dimmer);margin-bottom:20px">
    <a href="/" style="color:var(--dimmer)">keithah.com</a>
    <span style="margin:0 6px">/</span>
    <span style="color:var(--green)">{product.slug}</span>
    <span style="float:right;display:flex;gap:16px">
      <a href="#docs">docs</a>
      <a href="#changelog">changelog</a>
      <a href="#support">support</a>
      <a href={d.repo} target="_blank" rel="noopener">github</a>
    </span>
  </nav>

  <div class="product-hero">
    <div class="product-hero-head">
      <h1 class="product-name">{d.name}</h1>
      <span class="product-version">{d.version}</span>
    </div>
    <p class="product-tagline">{d.tagline}</p>
    <div class="product-cta-row">
      <a href={d.repo} class="btn" target="_blank" rel="noopener">View on GitHub &rarr;</a>
      <span class="product-meta-row">
        {d.platforms.join(' / ')}
        <span class="product-meta-sep">&middot;</span>{d.lang}
        <span class="product-meta-sep">&middot;</span>{d.license}
      </span>
    </div>
  </div>

  <hr />

  <div id="docs" class="prose" style="margin-bottom:28px">
    <Content />
  </div>

  {posts.length > 0 && (
    <>
      <hr />
      <div id="changelog">
        <div class="sh" style="margin-bottom:12px">changelog / related posts</div>
        <div class="changelog">
          {posts.map(p => (
            <div class="changelog-row">
              <span class="cl-date">{p.data.date.toISOString().slice(0,10)}</span>
              <a href={`/posts/${p.slug}`} class="cl-msg" style="color:var(--muted)">{p.data.title}</a>
            </div>
          ))}
        </div>
      </div>
    </>
  )}

  <hr />

  <div id="support">
    <div class="sh" style="margin-bottom:12px">support</div>
    <div class="support-box">
      <h3>open an issue</h3>
      <p>Found a bug or have a request? Open an issue on GitHub. Include your OS version and what you were doing when it broke.</p>
      <a href={`${d.repo}/issues/new`} class="btn" target="_blank" rel="noopener">open an issue on GitHub &rarr;</a>
    </div>
  </div>
    </>
  )}
</Base>
